# Copy this file to .env and fill in real values. .env is git-ignored.

# --- Bind mount ---
# Absolute path on the HOST machine that Claude Code will operate on.
# Mounted into the container at /workspace. Can point anywhere on the
# host filesystem, not just this repo's folder. Required - the container
# will refuse to start without it.
HOST_WORKDIR=/absolute/path/to/your/project

# --- Remote Ollama connection (manual setup) ---
# https://docs.ollama.com/integrations/claude-code#manual-setup
# Base URL of your remote Ollama server (or an ngrok/tunnel URL exposing it).
ANTHROPIC_BASE_URL=http://ollama-host.example.com:11434

# Placeholder auth token - Ollama ignores its value, but Claude Code
# requires the variable to be set to something non-empty.
ANTHROPIC_AUTH_TOKEN=ollama

# Must be present, but left EMPTY - Claude Code checks for this var,
# and a real Anthropic API key would take precedence over the base URL above.
ANTHROPIC_API_KEY=

# Model tag that already exists on the remote Ollama server (check with
# `ollama list` on that server). Example: qwen3-coder:30b
ANTHROPIC_MODEL=gemma4:31b-mlx

# Stop telemetry/update-check calls from leaving the container.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Map Claude Code's model tiers to a model your Ollama server actually has,
# so it doesn't request a cloud model name it can't resolve locally.
ANTHROPIC_DEFAULT_SONNET_MODEL=gemma4:31b-mlx
ANTHROPIC_DEFAULT_OPUS_MODEL=gemma4:31b-mlx
ANTHROPIC_DEFAULT_HAIKU_MODEL=gemma4:31b-mlx
